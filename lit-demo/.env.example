# Your wallet private key (used to sign Lit session)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# EAS attestation UID you got from your hackx backend
# (the tx hash from SubmitAttestation → look up the UID on basescan)
ATTESTATION_UID=0xYOUR_ATTESTATION_UID_HERE

# The secrets you want to protect (these get encrypted)
SECRET_DB_URL=postgres://hackx:hackx@localhost:5433/hackx
SECRET_API_KEY=super-secret-api-key-123
