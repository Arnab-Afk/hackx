# ── Backend───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://zkloud:zkloud@localhost:5432/zkloud?sslmode=disable
PORT=8080
DOCKER_HOST=unix:///var/run/docker.soc

# ── Antigravity proxy (Gemini) ─────────────────────────────────────────────
PROXY_URL=http://localhost:8080        # antigravity-claude-proxy
SCAN_MODEL=gemini-3.1-pro-high         # model used for repo analysis (once per deploy)
AGENT_MODEL=gemini-3-flash             # model used for deployment tool loop (fast)

# ── Contracts / Chain ─────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=...

# Populated automatically by deploy.ts + register-eas-schema.ts
PROVIDER_REGISTRY_ADDRESS=
DEPLOYMENT_ESCROW_ADDRESS=
EAS_SCHEMA_UID=

# ── Backend wallet (signs EAS attestations + calls recordJobCompleted) ────────
AGENT_WALLET_PRIVATE_KEY=0x...

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-secret

# ── Vault (LUKS workspace encryption) ────────────────────────────────────────
VAULT_MASTER_SECRET=change-me-to-a-random-32-char-secret

# ── GitHub OAuth (private repo access) ───────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
GITHUB_FRONTEND_URL=http://localhost:3000/deploy

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
