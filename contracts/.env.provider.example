# ──────────────────────────────────────────────────────
#  zkLOUD — Become a Compute Provider
#  Copy this file to .env (in the repo root) and fill in
#  your values, then run:
#
#    cd contracts
#    npm run become-provider
#
# ──────────────────────────────────────────────────────

# Your provider wallet private key (must hold >= 0.015 ETH on Base Sepolia)
PROVIDER_PRIVATE_KEY=0x_your_private_key_here

# PUBLIC HTTPS URL where your provider API is reachable from the internet
# The zkLOUD backend will call this URL to provision containers for users
PROVIDER_ENDPOINT=https://your-node.example.com

# How much you charge per container-hour, in wei
# 1000000000000000 = 0.001 ETH  (≈ $0.003 at $3/ETH — very cheap, good for testnet)
# 5000000000000000 = 0.005 ETH  (≈ $0.015 — recommended starting price)
PROVIDER_PRICE_PER_HOUR_WEI=1000000000000000

# ── These are already set by the deployment scripts ──
PROVIDER_REGISTRY_ADDRESS=0x889a1EB1489626F39C84b880a67e5eeAE3dD6884
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
